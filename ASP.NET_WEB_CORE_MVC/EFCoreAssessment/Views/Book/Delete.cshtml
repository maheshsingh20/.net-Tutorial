@model EFCoreAssessment.Models.Book

<!DOCTYPE html>
<html>
<head>
    <title>Delete Book</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="container">
        <h2>Delete Book</h2>

        <div class="alert">
            <h4>Are you sure you want to delete this book?</h4>
        </div>

        <div class="details-box">
            <dl>
                <dt>Book ID</dt>
                <dd>@Model.BookId</dd>

                <dt>Title</dt>
                <dd>@Model.Title</dd>

                <dt>Author</dt>
                <dd>@Model.Author</dd>

                <dt>Price</dt>
                <dd>@Model.Price.ToString("C")</dd>
            </dl>
        </div>

        <form asp-action="Delete" method="post" class="actions">
            <input type="hidden" asp-for="BookId" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="List" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</body>
</html>
